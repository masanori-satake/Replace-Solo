{
  "manifest_version": 3,
  "name": "Replace-Solo",
  "version": "0.5.2",
  "description": "〜データがブラウザの外に出ない、自分専用の固有名詞・一括置換ツール〜",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_title": "Open Side Panel"
  },
  "side_panel": {
    "default_path": "pages/sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "lib/kuromoji/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}

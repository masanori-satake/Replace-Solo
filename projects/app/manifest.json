{
  "manifest_version": 3,
  "name": "Replace-Solo",
  "version": "0.15.0",
  "description": "〜ブラウザ内で処理が完結するMicrosoft Loop専用の置換ツール〜",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "scripting",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://loop.microsoft.com/*",
    "https://loop.cloud.microsoft/*"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_title": "Replace-Solo (サポートされていないページ)",
    "default_icon": {
      "16": "assets/icons/icon16_gray.png",
      "32": "assets/icons/icon32_gray.png",
      "48": "assets/icons/icon48_gray.png",
      "128": "assets/icons/icon128_gray.png"
    }
  },
  "side_panel": {
    "default_path": "pages/sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "lib/kuromoji/*"
      ],
      "matches": [
        "https://loop.microsoft.com/*",
        "https://loop.cloud.microsoft/*"
      ]
    }
  ]
}

{
  "manifest_version": 3,
  "name": "Replace-Solo",
  "version": "0.1.0",
  "description": "〜データがブラウザの外に出ない、自分専用の固有名詞・一括置換ツール〜",
  "icons": {
    "128": "assets/icons/icon.svg"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Side Panel"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/kuromoji/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
